3 Задание:

Скрипт template_task.sh:

root@eltex-practice2-v38:~# cat template_task.sh
#!/bin/bash

# template_task.sh - шаблон для рабочих задач

SCRIPT_NAME=$(basename "$0")
PID=$$
PIPE="/tmp/run/cuckoo.pid"

log_message() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') [$PID] $1" >> "report_${SCRIPT_NAME%.*}.log"
}

if [ "$SCRIPT_NAME" = "template_task.sh" ]; then
    echo "я бригадир, сам не работаю"
    exit 1
fi

log_message "Скрипт запущен"

if [ ! -p "$PIPE" ]; then
    log_message "Ошибка: Канал $PIPE не найден"
    exit 1
fi

REQUEST="$SCRIPT_NAME[$PID]: how much time do I have?"
echo "$REQUEST" > "$PIPE"

if read N < "$PIPE"; then
    log_message "Получено время: $N секунд"
    sleep "$N"
    log_message "Скрипт завершился, работал $N секунд"
else
    log_message "Ошибка: Не удалось получить время от cuckoo"
    exit 1
fi






4 Задание:

_FILE="observer.log"
SCRIPT_DIR="$(dirname "$0")"

log_message() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG_FILE"
}

if [ ! -f "$CONFIG_FILE" ]; then
    echo "Ошибка: Файл конфигурации $CONFIG_FILE не найден"
    exit 1
fi

while IFS= read -r script_name || [ -n "$script_name" ]; do
    [[ -z "$script_name" || "$script_name" =~ ^# ]] && continue
    
    if [ ! -f "$SCRIPT_DIR/$script_name" ]; then
        log_message "Ошибка: Скрипт $script_name не найден"
        continue
    fi
    
    if pgrep -f "$script_name" > /dev/null 2>&1; then
        log_message "Процесс $script_name уже запущен"
    else
        log_message "Запуск процесса $script_name"
        cd "$SCRIPT_DIR" && nohup "./$script_name" > /dev/null 2>&1 &

	#Проверяем, что процесс запущен
        sleep 1
        if pgrep -f "$script_name" > /dev/null 2>&1; then
            log_message "Процесс $script_name успешно запущен (PID: $(pgrep -f "$script_name"))"
        else
            log_message "Ошибка: Не удалось запустить $script_name"
        fi
    fi
done < "$CONFIG_FILE"






