1 Задание:


Напишем скрипт cuckoo.sh на Bash:

root@eltex-practice2-v38:~# cat cuckoo.sh
#!/bin/bash
SCRIPT_NAME="cuckoo"
LOG_FILE="cuckoo.log"
PIPE_DIR="/tmp/run"
PIPE_NAME="cuckoo.pid"
PID_FILE="/tmp/cuckoo.pid"

mkdir -p "$PIPE_DIR"
rm -f "$PIPE_DIR/$PIPE_NAME"
mkfifo "$PIPE_DIR/$PIPE_NAME"

# Записываем PID скрипта в файл
echo $$ > "$PID_FILE"

log_message() {
    	echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG_FILE"
}

# Обработчик сигнала завершения
cleanup() {
	log_message "Shutdown!"
    	rm -f "$PIPE_DIR/$PIPE_NAME"
    	rm -f "$PID_FILE"
    	exit 0
}

trap cleanup SIGTERM SIGINT

log_message "Startup!"

while true; do
	if read request < "$PIPE_DIR/$PIPE_NAME"; then
        	if [[ "$request" =~ ^(.*)\[([0-9]+)\]:\ how\ much\ time\ do\ I\ have\?$ ]]; then
			NAME="${BASH_REMATCH[1]}"
            		PID="${BASH_REMATCH[2]}"
            		N=$(( (RANDOM % 9) + 2 ))
			
			# Возвращаем N в канал и в консоль
			echo "$N" > "$PIPE_DIR/$PIPE_NAME"
			echo "$N"

            		log_message "$NAME[$PID] $N"
        fi
    fi
done




Напишем скрипт-клиент test_client_cuckoo.sh на Bash который будет отправлять сообщение в канал, и будет принимать ответ с этого же канала, в запрос он записывает название скрипта, а это test_client_cuckoo.sh и передает PID своего процесса:

root@eltex-practice2-v38:~# cat test_client_cuckoo.sh 
#!/bin/bash
FIFO_PATH="/tmp/run/cuckoo.pid"

# Проверяем существование канала
if [[ ! -p "${FIFO_PATH}" ]]; then
    echo "Ошибка: Канал ${FIFO_PATH} не найден."
    exit 1
fi

NAME="${0##*/}"
PID=$$
REQUEST="${NAME}[${PID}]: how much time do I have?"

echo "${REQUEST}" > "${FIFO_PATH}"

if read -r answer < "${FIFO_PATH}"; then
    echo "Получен ответ: ${answer} секунд"
else
    echo "Ошибка: Не удалось прочитать ответ"
    exit 1
fi



