7 Задание:

Комментируем строку с observer.sh:
root@eltex-practice2-v38:~# crontab -e


Сделаем скрипт для разворачивания всей структуры

root@eltex-practice2-v38:~# cat deploy.sh 
#!/bin/bash

echo "Развертывание системы"

rm report_task*_worker.log
rm observer.log

chmod +x *.sh

for i in {1..5}; do
    ln -sf template_task.sh task${i}_worker.sh
done

cat > observer.conf << EOF
task1_worker.sh
task2_worker.sh
task3_worker.sh
task4_worker.sh
task5_worker.sh
EOF

nohup ./cuckoo.sh > /dev/null 2>&1 &
echo "cuckoo.sh запущен с PID: $!"

(crontab -l 2>/dev/null; echo "* * * * * cd $(pwd) && bash observer.sh >> /dev/null 2>&1") | crontab -
echo "Cron задача добавлена"

echo "Развертывание завершено"
echo "Наблюдайте за логами: tail -f observer.log"




И сделаем скрипт для завершения работы:
root@eltex-practice2-v38:~# cat stop.sh 
#!/bin/bash
echo "Остановка системы"

# Удаляем задачу из cron
crontab -l | grep -v observer.sh | crontab -
echo "Cron задача удалена"

pkill -f cuckoo.sh
pkill -f task1for_obs.sh
pkill -f observer.sh

rm -f /tmp/run/cuckoo.pid
rm -f /tmp/cuckoo.pid

echo "Очистка завершена"





