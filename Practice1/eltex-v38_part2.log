script -q eltex-v38_part.log
export PS1="\u@\h:\w\$ "
eltex-v38@eltex-2026-summer:~$ ls
ls           lsfd         lslogins     lspci
lsattr       lsinitramfs  lsmem        lsusb
lsblk        lsipc        lsmod        
lsb_release  lsirq        lsns         
lscpu        lslocks      lsof  

eltex-v38@eltex-2026-summer:~$ $HIST
$HISTCMD       $HISTFILE      $HISTSIZE      
$HISTCONTROL   $HISTFILESIZE 

ls -a ~/ | grep "^\."

echo $HISTFILESIZE
export HISTTIMEFORMAT="%F %T "
history 10
history | tail -5
tail -5 ~/.bash_history
export PROMPT_COMMAND="history -a"
date
history | tail -5
tail -5 ~/.bash_history

DATE=$(date +%Y-%m-%d)
echo $DATE

TIME=$(date +%H:%M:%S)
echo $TIME

DATE_TIME="$DATE $TIME"
echo $DATE_TIME

ls /bin /sbin | grep "[0-9]"

export PS1="\u@\h-$(date +%H:%M)> "

echo 'echo $PS1' > test_ps1.sh
bash --norc --noprofile
exit
